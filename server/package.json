{
  "name": "server",
  "license": "MIT",
  "main": "src/index.ts",
  "type": "commonjs",
  "dependencies": {
    "@xmldom/xmldom": "^0.8.11",
    "cors": "^2.8.6",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0",
    "multer": "^2.1.1",
    "socket.io": "^4.8.3"
  },
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "serve": "cd ../client && npm run build && cd ../server && npm run build && cross-env PORT=5203 node dist/index.js --serve-static",
    "tunnel": "cloudflared tunnel --url http://localhost:5203"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.0",
    "cross-env": "^10.1.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  }
}
